# Database (PostgreSQL — use Neon free tier: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth — generate with: openssl rand -base64 32
JWT_SECRET="change-me-in-production"

# Integrations (Phase A — filled in as you connect)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft Entra ID — used for both SSO login and data integration
# App registration: https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URIs to add:
#   https://<your-domain>/api/auth/microsoft/callback          (SSO)
#   https://<your-domain>/api/integrations/microsoft/callback  (data integration)
# API permissions: User.Read (delegated), User.Read.All + Directory.Read.All + AuditLog.Read.All (application, admin consent)
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"   # use "common" for multi-tenant, or your specific tenant ID

PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="sandbox"

# AI — Claude (primary, required for Advisor + Committee + Offboarding AI)
ANTHROPIC_API_KEY=""

# AI — OpenRouter (legacy redundancy analysis, optional)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="arcee-ai/trinity-large-preview:free"

# Apify — contact discovery for outreach
APIFY_API_KEY=""
